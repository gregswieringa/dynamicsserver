# Copy to deploy/staging.env on the deploy host and fill in real values.
# deploy/staging.env is gitignored -- it holds the staging DB password and
# is never committed. IMAGE_TAG is normally overwritten per-deploy by
# scripts/deploy.sh (it takes the tag as an argument); the value here is
# just what a manual `docker compose ... up` would fall back to.
POSTGRES_USER=buyer
POSTGRES_PASSWORD=changeme
POSTGRES_DB=marketplace
POSTGRES_PORT=5434
BUYER_API_PORT=8081
IMAGE_TAG=latest
