# Copy to deploy/prod.env on the deploy host and fill in real values.
# deploy/prod.env is gitignored -- it holds the production DB password and
# is never committed. Use a different POSTGRES_PASSWORD than staging's.
POSTGRES_USER=buyer
POSTGRES_PASSWORD=changeme
POSTGRES_DB=marketplace
POSTGRES_PORT=5435
BUYER_API_PORT=8082
IMAGE_TAG=latest
